<%= form_with(model: @transfer, local: true, class: "row g-3") do |f| %>
  <% if @transfer.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h4 class="alert-heading"><%= pluralize(@transfer.errors.count, "error") %> prohibited this transfer from being saved:</h4>
      <ul class="mb-0">
        <% @transfer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3 col-12 col-md-6">
    <%= f.label :storage_id, class: "form-label" %>
    <%= f.collection_select :storage_id, Storage.all, :id, :name, {prompt: true}, class: "form-select" %>
  </div>

  <div class="mb-3 col-12 col-md-6">
    <%= f.label :storage_to_id, "Destination Storage", class: "form-label" %>
    <%= f.collection_select :storage_to_id, Storage.all, :id, :name, {prompt: true}, class: "form-select" %>
  </div>

  <div class="mb-3 col-12 col-md-6">
    <%= f.label :transferred_at, class: "form-label" %>
    <%= f.datetime_local_field :transferred_at, class: "form-control", autocomplete: "off" %>
  </div>

  <div class="mb-3 col-12 col-md-6">
    <%= f.label :stock_state, class: "form-label" %>
    <%= f.select :stock_state, Transfer.stock_states.keys.map { |k| [k.titleize, k] }, {}, class: "form-select" %>
  </div>

  <h3 class="mt-4">Transfer Items</h3>
  <div id="transfer-items">
    <%= f.fields_for :transfer_items do |ti| %>
      <%= render partial: 'transfer_item_fields', locals: { f: ti } %>
    <% end %>
  </div>
  <div class="mb-3">
    <%= link_to 'Create Transfer Item', '#', id: 'add-transfer-item', class: 'btn btn-secondary' %>
  </div>

  <script type="text/template" id="transfer-item-template">
    <%= f.fields_for :transfer_items, TransferItem.new, child_index: 'NEW_RECORD' do |ti| %>
      <%= render partial: 'transfer_item_fields', locals: { f: ti } %>
    <% end %>
  </script>
  <script>
    var container = document.getElementById('transfer-items');
    var template = document.getElementById('transfer-item-template').innerHTML;
    document.getElementById('add-transfer-item').addEventListener('click', function(e) {
      e.preventDefault();
      var newId = new Date().getTime();
      var content = template.replace(/NEW_RECORD/g, newId);
      container.insertAdjacentHTML('beforeend', content);
    });
  </script>

  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
