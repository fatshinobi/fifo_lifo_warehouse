<%= form_with(model: @receiving, local: true, class: "row g-3") do |f| %>
  <% if @receiving.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h4 class="alert-heading"><%= pluralize(@receiving.errors.count, "error") %> prohibited this receiving from being saved:</h4>
      <ul class="mb-0">
        <% @receiving.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3 col-12 col-md-6">
    <%= f.label :storage_id, class: "form-label" %>
    <%= f.collection_select :storage_id, Storage.all, :id, :name, {prompt: true}, class: "form-select" %>
  </div>

  <div class="mb-3 col-12 col-md-6">
    <%= f.label :stock_state, class: "form-label" %>
    <%= f.select :stock_state, Receiving.stock_states.keys.map { |k| [k.titleize, k] }, {}, class: "form-select" %>
  </div>

  <div class="mb-3 col-12 col-md-6">
    <%= f.label :received_at, class: "form-label" %>
    <%= f.datetime_local_field :received_at, class: "form-control", autocomplete: "off" %>
  </div>

  <h3 class="mt-4">Receiving Items</h3>
  <div id="receiving-items">
    <%= f.fields_for :receiving_items do |ri| %>
      <%= render partial: 'receiving_item_fields', locals: { f: ri } %>
    <% end %>
  </div>
  <div class="mb-3">
    <%= link_to 'Add Receiving Item', '#', id: 'add-receiving-item', class: 'btn btn-secondary' %>
  </div>

  <script type="text/template" id="receiving-item-template">
    <%= f.fields_for :receiving_items, ReceivingItem.new, child_index: 'NEW_RECORD' do |ri| %>
      <%= render partial: 'receiving_item_fields', locals: { f: ri } %>
    <% end %>
  </script>
  <script>
    var container = document.getElementById('receiving-items');
    var template = document.getElementById('receiving-item-template').innerHTML;

    document.getElementById('add-receiving-item').addEventListener('click', function(e) {
      e.preventDefault();
      var newId = new Date().getTime();
      var content = template.replace(/NEW_RECORD/g, newId);
      container.insertAdjacentHTML('beforeend', content);
    });
  </script>

  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
