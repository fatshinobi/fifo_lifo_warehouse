<div class="nested-fields row g-2 align-items-end mb-2">
  <div class="col-12 col-md-4">
    <%= f.label :item_id, class: "form-label" %>
    <%= f.collection_select :item_id, Item.all, :id, :name, {prompt: true}, class: "form-select" %>
  </div>
  <div class="col-12 col-md-2">
    <%= f.label :qty, class: "form-label" %>
    <%= f.number_field :qty, min: 1, class: "form-control" %>
  </div>
  <div class="col-12 col-md-2">
    <%= f.label :cost, class: "form-label" %>
    <%= f.number_field :cost, step: 0.01, class: "form-control" %>
  </div>
  <div class="col-auto">
    <div class="form-check mt-2">
      <%= f.check_box :_destroy, class: "form-check-input" %>
      <%= f.label :_destroy, "Remove", class: "form-check-label" %>
    </div>
  </div>
</div>

