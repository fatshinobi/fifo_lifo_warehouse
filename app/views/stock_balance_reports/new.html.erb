<h1>Stock Balance Report Filters</h1>

<%= form_with url: stock_balance_reports_path, method: :get, local: true do |f| %>
  <div class="field">
    <%= f.label :item_id, "Item" %><br>
    <%= f.select :item_id, options_from_collection_for_select(@items, :id, :name), include_blank: true %>
  </div>

  <div class="field">
    <%= f.label :storage_id, "Storage" %><br>
    <%= f.select :storage_id, options_from_collection_for_select(@storages, :id, :name), include_blank: true %>
  </div>

  <div class="actions">
    <%= f.submit "Show Report" %>
  </div>
<% end %>

